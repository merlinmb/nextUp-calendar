# ─────────────────────────────────────────────────────────────
# nextUp Calendar — environment configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Port the app listens on (default: 3050)
PORT=3050

# The public URL of this app — used for OAuth callback URIs.
# For homebridge Docker deployment use your homebridge hostname.
APP_URL=http://homebridge.local:3050

# Node environment (development | production)
NODE_ENV=production

# Optional: override the auto-generated session secret.
# If left blank a secret is generated and persisted in data/.session_secret
# SESSION_SECRET=change-this-to-a-long-random-string

# Optional: set HTTPS=true only if you're terminating TLS in front of this app
# HTTPS=false
